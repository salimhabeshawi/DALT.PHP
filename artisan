#!/usr/bin/env php
<?php

$arguments = $argv;

function load_env_and_boot(): array {
    if (!defined('BASE_PATH')) {
        define('BASE_PATH', __DIR__ . '/');
    }
    if (!function_exists('base_path')) {
        function base_path(string $path = ''): string {
            return BASE_PATH . $path;
        }
    }
    require base_path('vendor/autoload.php');
    // Load env if present, otherwise continue silently
    $dotenv = Dotenv\Dotenv::createImmutable(base_path(''));
    if (method_exists($dotenv, 'safeLoad')) {
        $dotenv->safeLoad();
    } else {
        try { $dotenv->load(); } catch (\Throwable $e) { /* ignore missing .env */ }
    }
    $dbConfig = require base_path('config/database.php');
    return $dbConfig;
}

function platform_installed(): bool {
    return is_dir(base_path('.dalt'));
}

function require_platform(string $commandName): void {
    if (platform_installed()) {
        return;
    }

    echo "\nGuided learning is not installed (.dalt directory is missing).\n";
    echo "Command '{$commandName}' is only available when guided learning is present.\n";
    echo "This project is running as the framework core only.\n\n";
    exit(1);
}

if (count($arguments) < 2 || $arguments[1] === 'help' || $arguments[1] === '--help' || $arguments[1] === '-h') {
    echo "\n";
    echo "в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\n";
    echo "в•‘                    DALT.PHP Artisan CLI                      в•‘\n";
    echo "в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\n";
    echo "\n";
    echo "Usage: php artisan <command> [options]\n";
    echo "\n";
    echo "Available Commands:\n";
    echo "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n";
    echo "\n";
    
    echo "  dalt:test [challenge]   Run the test suite globally or for a specific challenge\n";
    echo "                          Example: php artisan dalt:test broken-auth\n";
    echo "\nDevelopment:\n";
    echo "  serve [host] [port]     Start PHP development server\n";
    echo "                          Example: php artisan serve\n";
    echo "                          Example: php artisan serve 0.0.0.0 8080\n";
    echo "\n";
    echo "  dev                     Start both PHP and Vite dev servers\n";
    echo "                          (Runs in background, use Ctrl+C to stop)\n";
    echo "\n";
    echo "Database:\n";
    echo "  migrate                 Run pending database migrations\n";
    echo "                          Executes .sql files from database/migrations/\n";
    echo "\n";
    echo "  migrate:fresh           Drop database and run all migrations\n";
    echo "                          WARNING: Deletes all data! (SQLite only)\n";
    echo "\n";
    echo "  make:migration <name>   Create a new SQL migration file\n";
    echo "                          Example: php artisan make:migration create_posts_table\n";
    echo "\n";
    echo "Testing:\n";
    echo "  test                    Run Pest test suite\n";
    echo "                          Executes all tests in tests/ directory\n";
    echo "\n";
    echo "  verify <challenge>      Verify a challenge (legacy, specify by name)\n";
    echo "\nChallenges (use challenge:* for the full workflow):\n";
    echo "  challenge:list          List all available challenges\n";
    echo "  challenge:start <name>  Load broken files for a challenge into your app\n";
    echo "  challenge:verify        Verify your fix (checks active challenge)\n";
    echo "  challenge:reset         Reset to buggy baseline (fresh start)\n";
    echo "  challenge:stop          Stop challenge and restore clean app\n";
    echo "\nGuided learning:\n";
    echo "  platform:status         Show whether guided learning is installed (.dalt)\n";
    echo "  platform:clean          Remove guided learning (framework core only)\n";
    echo "  platform:remove         Alias of platform:clean\n";
    echo "                          WARNING: This removes .dalt/ permanently!\n";
    echo "\nExamples:\n";
    echo "  example:install auth    Install authentication example\n";
    echo "                          Copies controllers, views, and routes\n";
    echo "\n";
    echo "Help:\n";
    echo "  help                    Show this help message\n";
    echo "\n";
    echo "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n";
    echo "\n";
    echo "For more information, visit: https://github.com/Ibnu-Afdel/DALT.PHP\n";
    echo "\n";
    exit(0);
}

// Bootstrap core for all commands so helpers like base_path() exist
$dbConfigBoot = load_env_and_boot();

$command = $arguments[1];

switch ($command) {
    case 'serve':
        $host = $arguments[2] ?? '127.0.0.1';
        $port = (int) ($arguments[3] ?? 8000);
        $maxTries = 50;
        $chosenPort = $port;
        $isFree = function(string $h, int $p): bool {
            $conn = @fsockopen($h, $p, $errno, $errstr, 0.2);
            if (is_resource($conn)) { fclose($conn); return false; }
            return true;
        };
        while ($maxTries-- > 0 && !$isFree($host, $chosenPort)) {
            $chosenPort++;
        }
        if ($chosenPort !== $port) {
            echo "Port {$port} in use. Using {$chosenPort} instead.\n";
        }
        echo "Starting development server: http://{$host}:{$chosenPort}\n";
        // Use router script for static files + front-controller routing
        passthru("php -S {$host}:{$chosenPort} -t public public/router.php");
        break;

    
    case 'dalt:test':
        require_platform($command);
        $dirs = array_filter(glob(base_path('.dalt/course/challenges/*')), 'is_dir');
        $challenges = array_map('basename', $dirs);
        
        $target = $arguments[2] ?? null;
        if ($target && in_array($target, $challenges)) {
            $challenges = [$target];
        } else if ($target) {
            echo "Challenge '$target' not found.\n";
            exit(1);
        }

        echo "\n=================================================\n";
        echo "             DALT.PHP TEST RUNNER                \n";
        echo "=================================================\n\n";

        require_once base_path('.dalt/Core/ChallengeVerifier.php');

        $totalTests = 0;
        $totalPassed = 0;

        foreach ($challenges as $ch) {
            echo "\033[1;36mChallenge: $ch\033[0m\n";
            $verifier = new \Core\ChallengeVerifier(".dalt/course/challenges/$ch");
            $result = $verifier->verify();
            
            $tests = $result['results'] ?? [];
            $chPassed = $result['passed'] ?? 0;
            $chTotal = $result['total'] ?? 0;
            
            $totalTests += $chTotal;
            $totalPassed += $chPassed;

            foreach ($tests as $name => $test) {
                if ($test['passed']) {
                    echo "  \033[32mвң” {$test['name']}\033[0m\n";
                } else {
                    echo "  \033[31mвңҳ {$test['name']}\033[0m - {$test['message']}\n";
                }
            }
            if ($chTotal === 0) {
                 echo "  \033[33mNo tests configured or found.\033[0m\n\n";
            } else if ($chPassed === $chTotal) {
                 echo "  \033[1;32mStatus: PASSED ($chPassed/$chTotal)\033[0m\n\n";
            } else {
                 echo "  \033[1;31mStatus: FAILED ($chPassed/$chTotal)\033[0m\n\n";
            }
        }
        
        echo "=================================================\n";
        echo " Total Progress: $totalPassed / $totalTests tests passed.\n";
        echo "=================================================\n\n";
        break;

    case 'migrate':
        $dbConfig = $dbConfigBoot;
        try {
            $database = new Core\Database($dbConfig['database']);
            $migration = new Core\Migration($database);
            $migration->runMigrations();
            echo "Migration process completed.\n";
        } catch (\Throwable $e) {
            echo "\n" . $e->getMessage() . "\n";
            exit(1);
        }
        break;

    case 'migrate:fresh':
        $dbConfig = $dbConfigBoot;
        echo "Running migrate:fresh...\n";
        $driver = $dbConfig['database']['driver'] ?? 'sqlite';
        if ($driver === 'sqlite') {
            $dbPath = $dbConfig['database']['database'];
            if (file_exists($dbPath)) {
                unlink($dbPath);
                echo "Dropped existing database file.\n";
            }
        } elseif ($driver === 'pgsql') {
            try {
                $database = new Core\Database($dbConfig['database']);
                $database->getConnection()->exec('DROP SCHEMA public CASCADE; CREATE SCHEMA public;');
                echo "Dropped and recreated public schema.\n";
            } catch (\Throwable $e) {
                echo "\nFailed to reset PostgreSQL schema.\n";
                echo $e->getMessage() . "\n";
                exit(1);
            }
        } else {
            echo "Warning: migrate:fresh for this driver is not implemented.\n";
        }
        try {
            $database = new Core\Database($dbConfig['database']);
            $migration = new Core\Migration($database);
            $migration->runMigrations();
            echo "Fresh migration completed.\n";
        } catch (\Throwable $e) {
            echo "\n" . $e->getMessage() . "\n";
            exit(1);
        }
        break;

    case 'make:migration':
        if (!isset($arguments[2])) {
            echo "Usage: php artisan make:migration <name>\n";
            echo "Example: php artisan make:migration create_posts_table\n";
            exit(1);
        }
        
        $name = $arguments[2];
        // Clean the name: remove 'create_' prefix and '_table' suffix if present
        $cleanName = preg_replace('/^create_/', '', $name);
        $cleanName = preg_replace('/_table$/', '', $cleanName);

        $dbConfig = $dbConfigBoot;
        $driver = $dbConfig['database']['driver'] ?? 'sqlite';
        if (!in_array($driver, ['sqlite', 'pgsql'], true)) {
            $driver = 'sqlite';
        }
        
        // Generate filename with timestamp
        $timestamp = date('YmdHis');
        $filename = "{$timestamp}_{$name}.sql";
        $relativeDir = 'database/migrations';
        $filepath = base_path("database/migrations/{$filename}");
        
        if (!is_dir(base_path('database/migrations'))) {
            mkdir(base_path('database/migrations'), 0755, true);
        }
        
        // Generate SQL template
        $currentDate = date('Y-m-d H:i:s');
        if ($driver === 'pgsql') {
            $template = <<<SQL
-- Migration: {$name}
-- Created: {$currentDate}

CREATE TABLE IF NOT EXISTS {$cleanName} (
    id BIGSERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Add indexes here
-- CREATE INDEX IF NOT EXISTS idx_{$cleanName}_name ON {$cleanName}(name);
SQL;
        } else {
            $template = <<<SQL
-- Migration: {$name}
-- Created: {$currentDate}

CREATE TABLE IF NOT EXISTS {$cleanName} (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name VARCHAR(255) NOT NULL,
    created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- Add indexes here
-- CREATE INDEX IF NOT EXISTS idx_{$cleanName}_name ON {$cleanName}(name);
SQL;
        }
        
        file_put_contents($filepath, $template);
        echo "Migration created: {$relativeDir}/{$filename}\n";
        echo "\n";
        echo "Next steps:\n";
        echo "1. Edit the migration file to define your table structure\n";
        echo "2. Run: php artisan migrate\n";
        break;

    case 'example:install':
        require_platform($command);
        $which = $arguments[2] ?? '';
        if ($which !== 'auth') {
            echo "Usage: php artisan example:install auth\n";
            exit(1);
        }
        $source = base_path('.dalt/stubs/auth');
        if (!is_dir($source)) {
            echo "Examples not found.\n";
            exit(1);
        }
        // Copy controllers
        @mkdir(base_path('app/Http/controllers/session'), 0755, true);
        @mkdir(base_path('app/Http/controllers/registration'), 0755, true);
        foreach (['session/create.php','session/store.php','session/destroy.php','registration/create.php','registration/store.php'] as $file) {
            copy($source . '/Http/controllers/' . $file, base_path('app/Http/controllers/' . $file));
        }
        // Copy views
        @mkdir(base_path('resources/views/auth'), 0755, true);
        foreach (['auth/login.view.php','auth/register.view.php'] as $file) {
            copy($source . '/resources/views/' . $file, base_path('resources/views/' . $file));
        }
        // Append routes
        $routesPath = base_path('routes/routes.php');
        $routeBlock = "\n// Auth example routes\n"
            . "\$router->get('/register', 'registration/create.php')->only('guest');\n"
            . "\$router->post('/register', 'registration/store.php')->only(['guest','csrf']);\n"
            . "\$router->get('/login', 'session/create.php')->only('guest');\n"
            . "\$router->post('/session', 'session/store.php')->only(['guest','csrf']);\n"
            . "\$router->delete('/session', 'session/destroy.php')->only(['auth','csrf']);\n";
        file_put_contents($routesPath, $routeBlock, FILE_APPEND);
        // Create marker so UI can show CTAs
        @mkdir(base_path('storage'), 0755, true);
        file_put_contents(base_path('storage/auth_example_installed'), date('c'));
        echo "Auth example installed and routes appended to routes/routes.php.\n";
        echo "Visit /register or /login (or see buttons on the welcome page).\n";
        break;

    case 'challenge:list':
        require_platform($command);
        require_once base_path('.dalt/Core/ChallengeManager.php');
        $metadata = Core\ChallengeManager::getChallengeMetadata();
        if (empty($metadata)) {
            echo "\nNo challenges found. Make sure .dalt/course/challenges/ exists.\n\n";
            break;
        }
        echo "\n";
        echo "в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\n";
        echo "в•‘                    Available Challenges                      в•‘\n";
        echo "в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\n\n";
        foreach ($metadata as $m) {
            $status = $m['passed'] ? "\033[32mвң“\033[0m" : " ";
            $line = sprintf("  %s %d. %-20s %-8s (%d bug%s)", $status, $m['num'], $m['id'], "[" . $m['difficulty'] . "]", $m['bugs'], $m['bugs'] === 1 ? '' : 's');
            echo $line . "\n";
        }
        echo "\nRun: php artisan challenge:start <name> to begin\n";
        echo "     php artisan challenge:verify when you think you fixed it\n\n";
        break;

    case 'challenge:start':
        require_platform($command);
        $challengeName = $arguments[2] ?? '';
        if (empty($challengeName)) {
            echo "Usage: php artisan challenge:start <challenge-name>\n";
            echo "Example: php artisan challenge:start broken-routing\n";
            echo "\nRun php artisan challenge:list to see available challenges.\n";
            exit(1);
        }
        require_once base_path('.dalt/Core/ChallengeManager.php');
        $challengeDir = base_path('.dalt/course/challenges/' . $challengeName);
        if (!is_dir($challengeDir)) {
            echo "Error: Challenge '{$challengeName}' not found.\n";
            echo "Run php artisan challenge:list to see available challenges.\n";
            exit(1);
        }
        $active = Core\ChallengeManager::getActiveChallenge();
        if ($active !== null || file_exists(base_path('routes/routes.php'))) {
            echo "\nвҡ пёҸ  This will overwrite files in framework/, routes/, app/Http/controllers/.\n";
            echo "Continue? [y/N]: ";
            $handle = fopen('php://stdin', 'r');
            $line = trim(fgets($handle));
            fclose($handle);
            if (strtolower($line) !== 'y' && strtolower($line) !== 'yes') {
                echo "Aborted.\n";
                exit(0);
            }
        }
        if (!Core\ChallengeManager::start($challengeName)) {
            echo "Error: Failed to start challenge.\n";
            exit(1);
        }
        echo "\nрҹҺҜ Challenge '{$challengeName}' loaded!\n\n";
        echo "Your app now has intentionally broken code. Fix the bugs in your IDE.\n\n";
        if (in_array($challengeName, ['broken-auth'], true)) {
            echo "Tip: Run \033[1mphp artisan migrate\033[0m if you haven't already (creates users table).\n\n";
        }
        echo "When ready, run: \033[1mphp artisan challenge:verify\033[0m\n";
        echo "Stuck? Run: \033[1mphp artisan challenge:reset\033[0m for a fresh start.\n\n";
        break;

    case 'challenge:reset':
        require_platform($command);
        require_once base_path('.dalt/Core/ChallengeManager.php');
        $active = Core\ChallengeManager::getActiveChallenge();
        if ($active === null) {
            echo "\nNo active challenge. Run php artisan challenge:start <name> first.\n\n";
            exit(0);
        }
        Core\ChallengeManager::reset();
        echo "\nрҹ”„ Challenge '{$active}' reset to buggy baseline. Ready for another try!\n\n";
        break;

    case 'challenge:stop':
        require_platform($command);
        require_once base_path('.dalt/Core/ChallengeManager.php');
        $active = Core\ChallengeManager::getActiveChallenge();
        if ($active === null) {
            echo "\nNo active challenge. Nothing to stop.\n\n";
            exit(0);
        }
        Core\ChallengeManager::stop();
        echo "\nвң… Challenge stopped. App restored to clean state.\n\n";
        break;

    case 'challenge:verify':
        require_platform($command);
        require_once base_path('.dalt/Core/ChallengeManager.php');
        require_once base_path('.dalt/Core/ChallengeVerifier.php');
        $active = Core\ChallengeManager::getActiveChallenge();
        if ($active === null) {
            echo "\nNo active challenge. Run: php artisan challenge:start <name>\n";
            echo "Then fix the bugs and run this again.\n\n";
            exit(1);
        }
        $challengePath = ".dalt/course/challenges/{$active}";
        $verifier = new Core\ChallengeVerifier($challengePath, true);
        $result = $verifier->verify();

        echo "\n";
        echo "в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\n";
        echo "в•‘           DALT Challenge Verification System                в•‘\n";
        echo "в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\n";
        echo "\nVerifying: {$active}\n";
        echo "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n";

        foreach ($result['results'] as $test) {
            $icon = $test['passed'] ? 'вң“' : 'вң—';
            $color = $test['passed'] ? "\033[32m" : "\033[31m";
            $reset = "\033[0m";
            echo "{$color}{$icon}{$reset} {$test['message']}\n";
            if (!$test['passed'] && !empty($test['hint'])) {
                echo "  рҹ’Ў Hint: {$test['hint']}\n";
            }
        }

        echo "\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n";
        echo "Results: {$result['passed']}/{$result['total']} tests passed\n";
        echo "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n";

        if ($result['status'] === 'pass') {
            Core\ChallengeManager::markPassed($active);
            echo "рҹҺү {$result['message']}\n\n";
            echo "Great job! You've successfully fixed this challenge.\n";
            echo "Run php artisan challenge:list to pick the next one.\n\n";
        } else {
            echo "вқҢ {$result['message']}\n\n";
            if (!empty($result['hint'])) {
                echo "рҹ’Ў Next step: {$result['hint']}\n\n";
            }
            echo "Keep debugging! Run php artisan challenge:reset for a fresh start.\n\n";
        }

        Core\ChallengeVerifier::logResult($active, $result);
        exit($result['status'] === 'pass' ? 0 : 1);

    case 'verify':
        require_platform($command);
        $challengeName = $arguments[2] ?? '';
        if (empty($challengeName)) {
            echo "Usage: php artisan verify <challenge-name>\n";
            echo "Example: php artisan verify broken-routing\n";
            echo "\nPreferred: php artisan challenge:start <name> then challenge:verify\n";
            echo "Available: broken-routing, broken-middleware, broken-auth, broken-database, broken-session\n";
            exit(1);
        }

        $challengePath = ".dalt/course/challenges/{$challengeName}";
        
        if (!is_dir(base_path($challengePath))) {
            echo "Error: Challenge '{$challengeName}' not found.\n";
            echo "Make sure the challenge exists in .dalt/course/challenges/ directory.\n";
            exit(1);
        }

        echo "\n";
        echo "в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\n";
        echo "в•‘           DALT Challenge Verification System                в•‘\n";
        echo "в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\n";
        echo "\n";
        echo "Verifying: {$challengeName}\n";
        echo "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n";

        $verifier = new Core\ChallengeVerifier($challengePath, true);
        $result = $verifier->verify();

        // Display results
        foreach ($result['results'] as $test) {
            $icon = $test['passed'] ? 'вң“' : 'вң—';
            $color = $test['passed'] ? "\033[32m" : "\033[31m";
            $reset = "\033[0m";
            
            echo "{$color}{$icon}{$reset} {$test['message']}\n";
            
            if (!$test['passed'] && !empty($test['hint'])) {
                echo "  рҹ’Ў Hint: {$test['hint']}\n";
            }
        }

        echo "\nв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n";
        echo "Results: {$result['passed']}/{$result['total']} tests passed\n";
        echo "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n\n";

        if ($result['status'] === 'pass') {
            echo "рҹҺү {$result['message']}\n\n";
            echo "Great job! You've successfully fixed this challenge.\n";
            echo "Check storage/logs/challenges.log for your progress.\n";
        } else {
            echo "вқҢ {$result['message']}\n\n";
            if (!empty($result['hint'])) {
                echo "рҹ’Ў Next step: {$result['hint']}\n\n";
            }
            echo "Keep debugging! Check the challenge README for more hints.\n";
        }

        echo "\n";

        // Log result
        Core\ChallengeVerifier::logResult($challengeName, $result);
        
        exit($result['status'] === 'pass' ? 0 : 1);

    case 'dev':
        require_platform($command);
        echo "Starting DALT.PHP development environment...\n";
        echo "\n";
        echo "This will start:\n";
        echo "  1. PHP development server (port 8000)\n";
        echo "  2. Vite dev server (port 5173)\n";
        echo "\n";
        echo "Press Ctrl+C to stop both servers.\n";
        echo "\n";
        echo "в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ\n";
        
        // Check if npm is available
        exec('which npm', $output, $npmCheck);
        if ($npmCheck !== 0) {
            echo "вҡ пёҸ  Warning: npm not found. Vite server will not start.\n";
            echo "   Install Node.js to enable the frontend: https://nodejs.org/\n";
            echo "\n";
            echo "Starting PHP server only...\n";
            passthru("php artisan serve");
            exit(0);
        }
        
        // Start both servers using concurrently if available, otherwise use background processes
        if (file_exists(base_path('.dalt/node_modules/.bin/concurrently'))) {
            passthru('cd ' . base_path('.dalt') . ' && npm run dev & php artisan serve');
        } else {
            echo "Starting servers...\n";
            echo "  вҶ’ PHP server: http://localhost:8000\n";
            echo "  вҶ’ Vite server: http://localhost:5173\n";
            echo "\n";
            
            // Start Vite in background
            $viteCmd = 'cd ' . base_path('.dalt') . ' && npm run dev > /dev/null 2>&1 &';
            exec($viteCmd);
            
            sleep(2); // Give Vite time to start
            
            // Start PHP server in foreground
            passthru("php artisan serve");
        }
        break;

    case 'test':
        echo "Running Pest test suite...\n";
        echo "\n";
        
        if (!file_exists(base_path('vendor/bin/pest'))) {
            echo "вҡ пёҸ  Pest is not installed.\n";
            echo "\n";
            echo "Install Pest by running:\n";
            echo "  composer require pestphp/pest --dev\n";
            echo "\n";
            exit(1);
        }
        
        passthru('vendor/bin/pest');
        break;

    case 'platform:status':
        echo "\n";
        if (platform_installed()) {
            echo "Guided learning: installed (.dalt found)\n";
            echo "Lessons, challenges, and related artisan commands are available.\n";
        } else {
            echo "Framework core only: guided learning not installed (.dalt not found)\n";
            echo "Lessons, challenges, and guided-learning artisan commands are disabled.\n";
        }
        echo "\n";
        break;

    case 'platform:clean':
    case 'platform:remove':
        if (!is_dir(base_path('.dalt'))) {
            echo "\nвң“ Guided learning layer already removed.\n";
            echo "DALT.PHP is running as the framework core only.\n\n";
            exit(0);
        }
        
        echo "\n";
        echo "в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—\n";
        echo "в•‘         Remove guided learning (.dalt)                     в•‘\n";
        echo "в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ\n";
        echo "\n";
        echo "This will permanently remove the guided learning layer and leave\n";
        echo "DALT.PHP as the framework core only.\n";
        echo "\n";
        echo "вҡ пёҸ  WARNING: This action cannot be undone!\n";
        echo "\n";
        echo "Do you want to continue? [y/N]: ";
        
        $handle = fopen("php://stdin", "r");
        $line = trim(fgets($handle));
        fclose($handle);
        
        if (strtolower($line) !== 'y' && strtolower($line) !== 'yes') {
            echo "\nCancelled. No changes made.\n\n";
            exit(0);
        }
        
        if (file_exists(base_path('.dalt/scripts/cleanup.php'))) {
            require base_path('.dalt/scripts/cleanup.php');
        } else {
            echo "\nError: Cleanup script not found.\n";
            echo "Please manually remove .dalt/ directory.\n\n";
            exit(1);
        }
        break;

    case 'help':
    case '--help':
    case '-h':
        // Help is handled at the top, but include here for completeness
        passthru("php artisan");
        break;

    default:
        echo "Unknown command: $command\n";
        echo "Run 'php artisan help' to see available commands.\n";
        exit(1);
}
