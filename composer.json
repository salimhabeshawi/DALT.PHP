{
    "name": "ibnuafdel/daltphp",
    "description": "Lightweight PHP micro-framework with optional built-in guided learning: lessons and broken-code challenges with automatic verification.",
    "type": "project",
    "license": "MIT",
    "version": "0.3.0-beta.2",
    "keywords": [
        "php",
        "framework",
        "learning",
        "education",
        "debugging",
        "backend",
        "tutorial",
        "sqlite",
        "vue",
        "tailwind",
        "vite",
        "laravel-inspired",
        "beginner-friendly"
    ],
    "homepage": "https://github.com/Ibnu-Afdel/DALT.PHP",
    "support": {
        "issues": "https://github.com/Ibnu-Afdel/DALT.PHP/issues",
        "source": "https://github.com/Ibnu-Afdel/DALT.PHP",
        "chat": "https://t.me/daltphp"
    },
    "authors": [
        {
            "name": "Ibnu Afdel",
            "email": "ibnuafdel@gmail.com",
            "role": "Creator & Maintainer"
        }
    ],
    "require": {
        "php": "^8.2",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "Core\\": [
                "framework/Core/",
                ".dalt/Core/"
            ],
            "App\\Http\\": "app/Http/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "serve": "php artisan serve",
        "test": "vendor/bin/pest",
        "migrate": "php artisan migrate",
        "migrate:fresh": "php artisan migrate:fresh",
        "make:migration": "php artisan make:migration",
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php .dalt/scripts/remove-vcs.php"
        ],
        "post-create-project-cmd": [
            "@php .dalt/scripts/post-create.php"
        ]
    },
    "bin": [
        "artisan"
    ],
    "archive": {
        "exclude": [
            ".git",
            ".github",
            ".gitignore",
            ".gitattributes",
            ".editorconfig",
            "phpunit.xml",
            "phpunit.xml.dist",
            "LICENSE",
            "SECURITY.md",
            "composer.lock",
            "package-lock.json"
        ]
    },
    "minimum-stability": "beta",
    "prefer-stable": true
}
